{
  "name": "Midnight Mint AMOLED",
  "author": "sparxz",
  "description": "Ultra-clean AMOLED black theme optimized for mobile devices with mint green accents, soft glow, large rounded corners, and premium card styling.",

  "colors": {
    "background": "#000000",
    "backgroundSecondary": "#050505",
    "backgroundTertiary": "#090909",

    "surface": "#0C0C0C",
    "surfaceSecondary": "#121212",
    "surfaceTertiary": "#181818",

    "primary": "#7FFFD4",
    "primaryHover": "#98FFE0",
    "primaryActive": "#66F2C5",

    "accent": "#7FFFD4",
    "accentSecondary": "#4DCCA8",

    "text": "#FFFFFF",
    "textSecondary": "#D0D0D0",
    "textMuted": "#8A8A8A",

    "success": "#7FFFD4",
    "warning": "#FFC857",
    "error": "#FF7070",

    "border": "#1A1A1A"
  },

  "ui": {
    "borderRadius": 30,
    "buttonRadius": 28,
    "cardRadius": 32,
    "inputRadius": 24,
    "modalRadius": 34,

    "messageSpacing": 12,
    "channelSpacing": 10,
    "buttonPadding": 14,

    "mobileOptimized": true
  },

  "effects": {
    "blur": 18,
    "shadow": true,
    "shadowOpacity": 0.45,

    "glow": true,
    "glowColor": "#7FFFD4",
    "glowIntensity": 0.15
  },

  "customCSS": {
    "--background-primary": "#000000",
    "--background-secondary": "#050505",
    "--background-tertiary": "#090909",

    "--surface-primary": "#0C0C0C",
    "--surface-secondary": "#121212",

    "--accent-primary": "#7FFFD4",
    "--accent-hover": "#98FFE0",
    "--accent-active": "#66F2C5",

    "--text-primary": "#FFFFFF",
    "--text-secondary": "#D0D0D0",
    "--text-muted": "#8A8A8A",

    "--radius-xs": "14px",
    "--radius-sm": "18px",
    "--radius-md": "24px",
    "--radius-lg": "30px",
    "--radius-xl": "36px",

    "--card-shadow": "0 8px 30px rgba(127,255,212,0.08)",
    "--button-shadow": "0 4px 18px rgba(127,255,212,0.12)",

    "--mobile-touch-size": "48px",

    "--message-bubble-radius": "26px",
    "--message-padding": "14px",

    "--channel-pill-radius": "20px",
    "--input-radius": "24px",

    "--header-height": "60px",
    "--sidebar-radius": "30px",

    "--mint-glow-soft": "0 0 12px rgba(127,255,212,0.15)",
    "--mint-glow-medium": "0 0 20px rgba(127,255,212,0.20)",
    "--mint-glow-strong": "0 0 30px rgba(127,255,212,0.25)"
  },

  "background": {
    "type": "solid",
    "color": "#000000"
  }
}